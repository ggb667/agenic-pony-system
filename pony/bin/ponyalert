#!/usr/bin/env bash
set -eu

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
voices_dir="$(cd "$script_dir/../assets/voices/askingForHelp" && pwd)"

personality="${1:-${PERSONALITY:-TWILIGHT_SPARKLE}}"
personality="$(printf '%s' "$personality" | tr '[:lower:]' '[:upper:]')"

case "$personality" in
  TIA|CELESTIA|PRINCESS|CELLY|SUNBUTT|PRINCESS_CELESTIA_SOL_INVICTUS)
    prefix="twilight_sparkle_"
    voice_label="celestia->twilight_sparkle"
    ;;
  TWI|TWILIGHT|TWILIGHT_SPARKLE)
    prefix="twilight_sparkle_"
    voice_label="twilight_sparkle"
    ;;
  DASH|DASHIE|RAINBOW|RD|RAINBOW_DASH)
    prefix="rainbow_dash_"
    voice_label="rainbow_dash"
    ;;
  PINKIE|PINKIE_PIE)
    prefix="pinkie_pie_"
    voice_label="pinkie_pie"
    ;;
  RARES|RARITY)
    prefix="rarity_"
    voice_label="rarity"
    ;;
  AJ|APPLEJACK)
    prefix="applejack_"
    voice_label="applejack"
    ;;
  SHY|FLUTTERS|FLUTTERSHY)
    prefix="fluttershy_"
    voice_label="fluttershy"
    ;;
  SPIKE)
    prefix="spike_"
    voice_label="spike"
    ;;
  *)
    prefix="twilight_sparkle_"
    voice_label="twilight_sparkle"
    ;;
esac

printf 'ponyalert voice: %s\n' "$voice_label" >&2

pony_debug() {
  if [ "${PONYDEBUG:-0}" = "1" ]; then
    printf 'ponyalert: %s\n' "$*" >&2
  fi
}

mapfile -d '' files < <(
  find "$voices_dir" -maxdepth 1 -type f -iname "${prefix}*.wav" -print0 | sort -z
)

if [ "${#files[@]}" -eq 0 ]; then
  pony_debug "no matching wav files for prefix ${prefix}; using double bell fallback"
  printf '\a\a'
  exit 0
fi

choice_index=$(( RANDOM % ${#files[@]} ))
chosen_wav="${files[$choice_index]}"
pony_debug "selected $chosen_wav"

run_with_timeout() {
  if command -v timeout >/dev/null 2>&1; then
    timeout 5s "$@"
  else
    "$@"
  fi
}

play_local() {
  if command -v ffplay >/dev/null 2>&1; then
    pony_debug "trying ffplay"
    run_with_timeout ffplay -nodisp -autoexit -loglevel error "$chosen_wav" >/dev/null 2>&1 && return 0
  fi
  if command -v aplay >/dev/null 2>&1; then
    pony_debug "trying aplay"
    run_with_timeout aplay -q "$chosen_wav" >/dev/null 2>&1 && return 0
  fi
  if command -v paplay >/dev/null 2>&1; then
    pony_debug "trying paplay"
    run_with_timeout paplay "$chosen_wav" >/dev/null 2>&1 && return 0
  fi
  return 1
}

play_wmplayer() {
  local win_tmp_dir base win_copy win_path ps enc

  command -v powershell.exe >/dev/null 2>&1 || return 1
  win_tmp_dir="/mnt/c/Users/${USER}/AppData/Local/Temp"
  [ -d "$win_tmp_dir" ] || return 1

  base="ponyalert-${prefix}$$-$RANDOM.wav"
  win_copy="$win_tmp_dir/$base"
  pony_debug "trying minimized wmplayer via $win_copy"
  cp "$chosen_wav" "$win_copy" >/dev/null 2>&1 || return 1

  win_path="C:\\Users\\${USER}\\AppData\\Local\\Temp\\$base"
  ps=$(cat <<EOF2
\$path = '$win_path'
\$p = Start-Process -FilePath 'C:\Program Files (x86)\Windows Media Player\wmplayer.exe' -ArgumentList \$path -WindowStyle Minimized -PassThru
Start-Sleep -Seconds 4
if (-not \$p.HasExited) {
  Stop-Process -Id \$p.Id -Force
}
Remove-Item \$path -ErrorAction SilentlyContinue
Write-Output 'wmplayer_ok'
EOF2
)
  enc=$(printf '%s' "$ps" | iconv -f UTF-8 -t UTF-16LE | base64 -w0)

  run_with_timeout powershell.exe -NoProfile -EncodedCommand "$enc" >/dev/null 2>&1 && return 0
  rm -f "$win_copy" >/dev/null 2>&1 || true
  return 1
}

play_fallback_beep() {
  pony_debug "using double bell fallback"
  printf '\a'
  sleep 0.15
  printf '\a'
}

play_wmplayer || play_local || play_fallback_beep
