#!/usr/bin/env bash
set -eu

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
voices_dir="$(cd "$script_dir/../assets/voices/askingForHelp" && pwd)"
source "$script_dir/../scripts/pony-paths.sh"
source "$script_dir/../scripts/pony-audio.sh"

default_personality="TWILIGHT_SPARKLE"
if [[ "$(basename "$repo_root")" == "agenic-pony-system" ]]; then
  default_personality="PRINCESS_CELESTIA_SOL_INVICTUS"
fi

load_project_paths "$repo_root"
export AGENIC_PONY_AUDIO_HOST_FIFO="$AGENIC_PROJECT_PONY_RUNTIME_DIR/audio.host.fifo"
export AGENIC_PONY_AUDIO_HOST_PID_FILE="$AGENIC_PROJECT_PONY_RUNTIME_DIR/audio.host.pid"

usage() {
  printf 'Usage: %s [PERSONALITY]\n' "$(basename "$0")" >&2
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "$#" -gt 1 ]]; then
  usage
  printf 'ERROR: expected at most one personality argument; got %s\n' "$#" >&2
  exit 64
fi

personality="${1:-${AGENIC_LAUNCH_PERSONALITY:-${PERSONALITY:-$default_personality}}}"
personality="$(printf '%s' "$personality" | tr '[:lower:]' '[:upper:]')"

case "$personality" in
  TIA|CELESTIA|PRINCESS|CELLY|SUNBUTT|PRINCESS_CELESTIA_SOL_INVICTUS)
    prefix="princess_celestia_"
    voice_label="princess_celestia"
    ;;
  TWI|TWILIGHT|TWILIGHT_SPARKLE)
    prefix="twilight_sparkle_"
    voice_label="twilight_sparkle"
    ;;
  DASH|DASHIE|RAINBOW|RD|RAINBOW_DASH)
    prefix="rainbow_dash_"
    voice_label="rainbow_dash"
    ;;
  PINKIE|PINKIE_PIE)
    prefix="pinkie_pie_"
    voice_label="pinkie_pie"
    ;;
  RARES|RARITY)
    prefix="rarity_"
    voice_label="rarity"
    ;;
  AJ|APPLEJACK)
    prefix="applejack_"
    voice_label="applejack"
    ;;
  SHY|FLUTTERS|FLUTTERSHY)
    prefix="fluttershy_"
    voice_label="fluttershy"
    ;;
  SPIKE)
    prefix="spike_"
    voice_label="spike"
    ;;
  *)
    prefix="twilight_sparkle_"
    voice_label="twilight_sparkle"
    ;;
esac

if [ "$prefix" = "princess_celestia_" ] && ! find "$voices_dir" -maxdepth 1 -type f -iname "${prefix}*.wav" | read -r _; then
  prefix="twilight_sparkle_"
  voice_label="celestia->twilight_sparkle"
fi

mapfile -d '' files < <(
  find "$voices_dir" -maxdepth 1 -type f -iname "${prefix}*.wav" -print0 | sort -z
)

if [ "${#files[@]}" -eq 0 ]; then
  pony_audio_debug "ponyalert" "no matching wav files for prefix ${prefix}; using double bell fallback"
  printf '\a\a'
  exit 0
fi

choice_index=$(( RANDOM % ${#files[@]} ))
chosen_wav="${files[$choice_index]}"
chosen_name="$(basename "$chosen_wav" .wav)"
pony_audio_debug "ponyalert" "selected $chosen_wav"
printf '%s\n' "$chosen_name"
pony_audio_request_host_play "ponyalert" "$prefix" "$chosen_wav" "$chosen_name" "ponyalert" || \
  pony_audio_play_direct "ponyalert" "$prefix" "$chosen_wav" "$chosen_name" "ponyalert"
