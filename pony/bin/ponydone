#!/usr/bin/env bash
set -eu

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
voices_dir="$(cd "$script_dir/../assets/voices/doneWithTask" && pwd)"
source "$script_dir/../scripts/pony-paths.sh"
source "$script_dir/../scripts/pony-audio.sh"

default_personality="TWILIGHT_SPARKLE"
if [[ "$(basename "$repo_root")" == "agenic-pony-system" ]]; then
  default_personality="PRINCESS_CELESTIA_SOL_INVICTUS"
fi

load_project_paths "$repo_root"
export AGENIC_PONY_AUDIO_HOST_FIFO="$AGENIC_PROJECT_PONY_RUNTIME_DIR/audio.host.fifo"
export AGENIC_PONY_AUDIO_HOST_PID_FILE="$AGENIC_PROJECT_PONY_RUNTIME_DIR/audio.host.pid"

usage() {
  printf 'Usage: %s [PERSONALITY]\n' "$(basename "$0")" >&2
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "$#" -gt 1 ]]; then
  usage
  printf 'ERROR: expected at most one personality argument; got %s\n' "$#" >&2
  exit 64
fi

personality="${1:-${AGENIC_LAUNCH_PERSONALITY:-${PERSONALITY:-$default_personality}}}"
personality="$(printf '%s' "$personality" | tr '[:lower:]' '[:upper:]')"

case "$personality" in
  TIA|CELESTIA|PRINCESS|CELLY|SUNBUTT|PRINCESS_CELESTIA_SOL_INVICTUS) prefix="princess_celestia_" ;;
  TWI|TWILIGHT|TWILIGHT_SPARKLE) prefix="twilight_sparkle_" ;;
  DASH|DASHIE|RAINBOW|RD|RAINBOW_DASH) prefix="rainbow_dash_" ;;
  PINKIE|PINKIE_PIE) prefix="pinkie_pie_" ;;
  RARES|RARITY) prefix="rarity_" ;;
  AJ|APPLEJACK) prefix="applejack_" ;;
  SHY|FLUTTERS|FLUTTERSHY) prefix="fluttershy_" ;;
  SPIKE) prefix="spike_" ;;
  *) prefix="twilight_sparkle_" ;;
esac

if [ "$prefix" = "princess_celestia_" ] && ! find "$voices_dir" -maxdepth 1 -type f -iname "${prefix}*.wav" | read -r _; then
  prefix="twilight_sparkle_"
fi

mapfile -d '' files < <(
  find "$voices_dir" -maxdepth 1 -type f -iname "${prefix}*.wav" -print0 | sort -z
)

if [ "${#files[@]}" -eq 0 ]; then
  pony_audio_debug "ponydone" "no matching wav files for prefix ${prefix}; using double bell fallback"
  printf '\a\a'
  exit 0
fi

choice_index=$(( RANDOM % ${#files[@]} ))
chosen_wav="${files[$choice_index]}"
chosen_name="$(basename "$chosen_wav" .wav)"
pony_audio_debug "ponydone" "selected $chosen_wav"
printf '%s\n' "$chosen_name"

pony_audio_request_host_play "ponydone" "$prefix" "$chosen_wav" "$chosen_name" "ponydone" || \
  pony_audio_play_direct "ponydone" "$prefix" "$chosen_wav" "$chosen_name" "ponydone"
