#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
agenic_root="$(cd "$script_dir/../.." && pwd)"
source "$agenic_root/pony/scripts/launch-debug.sh"
source "$agenic_root/pony/scripts/pony-paths.sh"
source "$agenic_root/pony/bin/codex-prompt-style.sh"
current_script="$script_dir/$(basename "${BASH_SOURCE[0]}")"
pony_launch_debug_init

project_root="$(detect_project_root "${PWD}")"
load_project_paths "$project_root"
pony_launch_debug "codex-pony entry: pwd=$PWD project_root=$project_root current_script=$current_script arg_count=$#"

if [[ ! -f "$AGENIC_PROJECT_PONY_CONFIG_PATH" ]]; then
  "$agenic_root/scripts/install-project.sh" "$project_root" >/dev/null
  load_project_paths "$project_root"
fi

project_codex_pony="$project_root/pony/bin/codex-pony"
if [[ "$project_root" != "$agenic_root" ]] && [[ "${AGENIC_PONY_REFRESH_REEXEC:-0}" != "1" ]] && [[ -x "$project_codex_pony" ]] && [[ "$current_script" != "$project_codex_pony" ]]; then
  export AGENIC_PONY_REFRESH_REEXEC=1
  pony_launch_debug "codex-pony reexec project wrapper: project_codex_pony=$project_codex_pony"
  exec "$project_codex_pony" "$@"
fi

if [[ -n "${WARP_LAUNCH_CONFIG_DIR:-}" || -d /mnt/c/Users/"$USER"/AppData/Roaming/warp/Warp/data/launch_configurations ]]; then
  "$agenic_root/scripts/install-warp-launch-configs.sh" "$project_root" >/dev/null || true
fi

source_launch_env() {
  local env_file=""

  if [[ -n "${AGENIC_PONY_ENV_FILE:-}" ]]; then
    env_file="${AGENIC_PONY_ENV_FILE}"
  elif [[ -f "$AGENIC_PROJECT_PONY_RUNTIME_DIR/launch.env" ]]; then
    env_file="$AGENIC_PROJECT_PONY_RUNTIME_DIR/launch.env"
  else
    env_file="$(default_launch_env_file "$AGENIC_PROJECT_ROOT")"
  fi

  [[ -n "$env_file" ]] || return 0
  if [[ ! -f "$env_file" ]]; then
    pony_launch_debug "codex-pony launch env missing: env_file=$env_file"
    return 0
  fi

  set -a
  source "$env_file"
  set +a
  pony_launch_debug "codex-pony launch env loaded: env_file=$env_file github_token=$( [[ -n "${GITHUB_PAT_TOKEN:-}" ]] && printf 'present' || printf 'missing' )"
}

source_launch_env

preferred_repo_codex="/home/ggb66/dev/codex/codex-rs/target/debug/codex-tui"
effective_codex_profile="${CODEX_PONY_PROFILE:-}"
profile_config_path=""
if [[ -n "$effective_codex_profile" ]]; then
  profile_config_path="${CODEX_HOME:-$HOME/.codex}/${effective_codex_profile}.config.toml"
fi
codex_bin="${CODEX_PONY_BIN:-}"
if [[ -z "$codex_bin" ]]; then
  if [[ -x "$preferred_repo_codex" ]]; then
    codex_bin="$preferred_repo_codex"
  elif command -v codex >/dev/null 2>&1; then
    codex_bin="codex"
  elif [[ -x /tmp/codex-pony-target/debug/codex-tui ]]; then
    codex_bin="/tmp/codex-pony-target/debug/codex-tui"
  fi
fi

if [[ -z "$codex_bin" ]]; then
  pony_launch_debug "codex-pony error: no codex binary available"
  echo "ERROR: codex is not available on PATH" >&2
  exit 1
fi

if [[ -x "$AGENIC_PROJECT_PONY_SCRIPTS_DIR/queue-runtime.sh" ]]; then
  "$AGENIC_PROJECT_PONY_SCRIPTS_DIR/queue-runtime.sh" init >/dev/null
fi

append_codex_profile_args() {
  local profile="$1"
  local line key value

  if [[ "$(basename "$codex_bin")" != "codex-tui" || ! -f "$profile_config_path" ]]; then
    codex_args+=(-p "$profile")
    return 0
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -n "$line" ]] || continue
    [[ "$line" != \[* ]] || continue
    [[ "$line" == *=* ]] || continue

    key="${line%%=*}"
    value="${line#*=}"
    key="${key%"${key##*[![:space:]]}"}"
    value="${value#"${value%%[![:space:]]*}"}"
    codex_args+=(-c "$key=$value")
  done <"$profile_config_path"
}

codex_args=()
if glyph="$(codex_prompt_glyph_for_personality "${PERSONALITY:-}" 2>/dev/null)"; then
  codex_args+=(-c "tui.prompt_glyph=\"$glyph\"")
fi
if background="$(codex_prompt_background_for_personality "${PERSONALITY:-}" 2>/dev/null)"; then
  codex_args+=(-c "tui.prompt_background=\"$background\"")
fi
if [[ -n "${PERSONALITY:-}" ]]; then
  codex_args+=(-c "tui.terminal_title=[]")
fi
if [[ -n "$effective_codex_profile" ]]; then
  append_codex_profile_args "$effective_codex_profile"
fi
if [[ -n "${CODEX_PONY_PID_FILE:-}" ]]; then
  printf '%s\n' "$$" >"$CODEX_PONY_PID_FILE"
fi

profile_arg="none"
if [[ -n "$effective_codex_profile" ]]; then
  profile_arg="$effective_codex_profile"
elif [[ "${1:-}" == "-p" ]] && [[ -n "${2:-}" ]]; then
  profile_arg="$2"
fi
pony_launch_debug "codex-pony exec: codex_bin=$codex_bin profile=$profile_arg project_root=$project_root stdin_tty=$( [[ -t 0 ]] && printf yes || printf no ) project_root=$project_root"
if [[ ! -t 0 || ! -t 1 ]]; then
  if ( : </dev/tty ) 2>/dev/null; then
    pony_launch_debug "codex-pony rebind stdio to /dev/tty before exec: stdin_tty=$( [[ -t 0 ]] && printf yes || printf no ) stdout_tty=$( [[ -t 1 ]] && printf yes || printf no )"
    exec "$codex_bin" "${codex_args[@]}" "$@" </dev/tty >/dev/tty 2>&1
  fi
fi
exec "$codex_bin" "${codex_args[@]}" "$@"
